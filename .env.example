# ─────────────────────────────────────────
# Quick Invoice — Environment Variables
# Copy this file to .env.local for local development.
# Never commit .env.local to source control.
# ─────────────────────────────────────────

# ── App ──────────────────────────────────
# Full public URL of the app (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_VERSION=0.1.0
NEXT_PUBLIC_APP_NAME=quick-invoice

# ── Database (Supabase) ───────────────────
# Connection pooling URL (for Prisma runtime queries — uses pgBouncer)
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true

# Direct connection URL (for Prisma migrations — bypasses pgBouncer)
DIRECT_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres

# ── NextAuth ─────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret-here
# Must match NEXT_PUBLIC_APP_URL in production
NEXTAUTH_URL=http://localhost:3000

# ── OAuth Providers ──────────────────────
# Google OAuth — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth — https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Stripe ───────────────────────────────
# Stripe Dashboard → Developers → API Keys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe webhook secret — generate with: stripe listen --print-secret
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs — create in Stripe Dashboard → Products
# Pro plan ($12/month)
STRIPE_PRO_PRICE_ID=price_...
# Team plan ($29/month)
STRIPE_TEAM_PRICE_ID=price_...

# ── Email ────────────────────────────────
# Resend (https://resend.com) — recommended
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@quickinvoice.app

# ── Supabase (Storage + optional Auth) ───
NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT-REF].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Analytics ────────────────────────────
# Google Analytics 4 — https://analytics.google.com
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Plausible Analytics — https://plausible.io
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=quickinvoice.app

# PostHog — https://posthog.com
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ── Monitoring & Error Tracking ──────────
# Sentry — https://sentry.io
# DSN from Sentry Project Settings → Client Keys
NEXT_PUBLIC_SENTRY_DSN=https://xxx@oxx.ingest.sentry.io/xxx

# Sentry CLI auth token (for source map uploads — CI only)
# Generate at https://sentry.io/settings/account/api/auth-tokens/
SENTRY_AUTH_TOKEN=sntrys_...

# Sentry organisation slug (from your Sentry org URL)
SENTRY_ORG=your-org-slug

# Sentry project slug (from Project Settings → General)
SENTRY_PROJECT=quick-invoice

# ── Performance Thresholds ───────────────
# Log a warning when any API route exceeds this duration (ms)
SLOW_REQUEST_THRESHOLD_MS=2000

# Log an error (+ trigger alert) when any API route exceeds this (ms)
ALERT_THRESHOLD_MS=5000

# ── Logging ──────────────────────────────
# Minimum log level: debug | info | warn | error
LOG_LEVEL=info

# ── Uptime Monitoring ────────────────────
# BetterUptime / UptimeRobot monitor IDs (for reference only, set in dashboard)
# Healthcheck endpoint: https://yourdomain.com/api/health
# See reports/monitoring-setup.md for full uptime monitoring setup.
