# ─────────────────────────────────────────
# Quick Invoice — Environment Variables
# Copy this file to .env.local for local development.
# Never commit .env.local to source control.
# ─────────────────────────────────────────

# ── App ──────────────────────────────────
# Full public URL of the app (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Database ─────────────────────────────
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=postgresql://postgres:password@localhost:5432/quick_invoice

# ── NextAuth ─────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret-here
# Must match NEXT_PUBLIC_APP_URL in production
NEXTAUTH_URL=http://localhost:3000

# ── OAuth Providers ──────────────────────
# Google OAuth — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth — https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Stripe ───────────────────────────────
# Stripe Dashboard → Developers → API Keys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe webhook secret — generate with: stripe listen --print-secret
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs — create in Stripe Dashboard → Products
# Pro plan ($12/month)
STRIPE_PRO_PRICE_ID=price_...
# Team plan ($29/month)
STRIPE_TEAM_PRICE_ID=price_...

# ── Email (choose one provider) ──────────
# Option A: Resend (recommended — https://resend.com)
RESEND_API_KEY=re_...

# Option B: SMTP (Nodemailer)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@quickinvoice.app

# ── Storage (optional — for logo uploads) ─
# AWS S3 / Cloudflare R2 for user logo uploads
STORAGE_BUCKET=
STORAGE_REGION=
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_PUBLIC_URL=
